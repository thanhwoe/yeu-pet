generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model accounts {
  id                      String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email                   String?               @unique @db.VarChar(255)
  first_name              String?               @db.VarChar(255)
  last_name               String?               @db.VarChar(255)
  password_hash           String                @db.VarChar(255)
  phone                   String                @unique @db.VarChar(20)
  avatar_url              String?
  role                    user_role             @default(user)
  onboarding_completed    Boolean               @default(false)
  subscription            subscription_tier     @default(free)
  subscription_expires_at DateTime?             @db.Timestamptz(6)
  last_sign_in_at         DateTime?             @db.Timestamptz(6)
  created_at              DateTime?             @default(now()) @db.Timestamptz(6)
  updated_at              DateTime?             @default(now()) @db.Timestamptz(6)
  is_active               Boolean?              @default(true)
  is_verified             Boolean?              @default(false)
  avatar_id               String?
  account_devices         account_devices[]
  account_settings        account_settings?
  budget_transactions     budget_transactions[]
  budgets                 budgets[]
  notifications           notifications[]
  otp_tokens              otp_tokens?
  pets                    pets[]
  photo_comments          photo_comments[]
  photo_likes             photo_likes[]
  photo_views             photo_views[]
  photos                  photos[]
  refresh_tokens          refresh_tokens[]
  reminders               reminders[]

  @@index([email], map: "idx_accounts_email")
  @@index([phone], map: "idx_accounts_phone")
}

model refresh_tokens {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  account_id String    @db.Uuid
  token_hash String    @unique
  expires_at DateTime  @db.Timestamptz(6)
  revoked_at DateTime? @db.Timestamptz(6)
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  updated_at DateTime? @default(now()) @db.Timestamptz(6)
  accounts   accounts  @relation(fields: [account_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_refresh_tokens_account_id")

  @@index([token_hash], map: "idx_refresh_tokens_token_hash")
}

model otp_tokens {
  account_id String    @id @db.Uuid
  token      String?
  expires_at DateTime? @db.Timestamptz(6)
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  updated_at DateTime? @default(now()) @db.Timestamptz(6)
  accounts   accounts  @relation(fields: [account_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_otp_tokens_account_id")

  @@index([account_id], map: "idx_otp_tokens_account_id")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model medical_records {
  id                  String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  pet_id              String                @db.Uuid
  record_type         record_type
  title               String                @db.VarChar(200)
  description         String?
  date                DateTime?             @db.Timestamptz(6)
  vet_clinic          String?               @db.VarChar(200)
  vet_name            String?               @db.VarChar(100)
  created_at          DateTime?             @default(now()) @db.Timestamptz(6)
  updated_at          DateTime?             @default(now()) @db.Timestamptz(6)
  medical_attachments medical_attachments[]
  pets                pets                  @relation(fields: [pet_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_medical_records_pet_id")

  @@index([id], map: "idx_medical_records")
  @@index([pet_id], map: "idx_medical_records_pet_id")
}

model pets {
  id              String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  account_id      String            @db.Uuid
  name            String            @db.VarChar(100)
  age             Int?              @db.SmallInt
  birthdate       DateTime?         @db.Timestamptz(6)
  breed           String?           @db.VarChar(100)
  weight          String?           @db.VarChar(100)
  color           String?           @db.VarChar(100)
  avatar_url      String?
  gender          gender_enum?      @default(unknown)
  species         species_enum?     @default(other)
  notes           String?
  created_at      DateTime?         @default(now()) @db.Timestamptz(6)
  updated_at      DateTime?         @default(now()) @db.Timestamptz(6)
  avatar_id       String?
  medical_records medical_records[]
  accounts        accounts          @relation(fields: [account_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_pets_account_id")
  reminders       reminders[]

  @@index([id], map: "idx_pets")
  @@index([account_id], map: "idx_pets_account_id")
}

model medical_attachments {
  id              String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  medical_id      String          @db.Uuid
  deleted_at      DateTime?       @db.Timestamptz(6)
  url             String
  public_id       String?
  created_at      DateTime?       @default(now()) @db.Timestamptz(6)
  updated_at      DateTime?       @default(now()) @db.Timestamptz(6)
  medical_records medical_records @relation(fields: [medical_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_medical_attachments_medical_id")

  @@index([id], map: "idx_medical_attachments")
  @@index([medical_id], map: "idx_medical_attachments_medical_id")
}

model account_devices {
  id                      String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  account_id              String                    @db.Uuid
  push_token              String                    @unique @db.VarChar(512)
  device_name             String?                   @db.VarChar(100)
  os_version              String?                   @db.VarChar(20)
  platform                device_platform?          @default(unknown)
  is_active               Boolean?                  @default(true)
  created_at              DateTime?                 @default(now()) @db.Timestamptz(6)
  updated_at              DateTime?                 @default(now()) @db.Timestamptz(6)
  accounts                accounts                  @relation(fields: [account_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_account_devices_account_id")
  notification_deliveries notification_deliveries[]

  @@index([account_id], map: "idx_account_account_id")
  @@index([id], map: "idx_account_devices")
  @@index([push_token], map: "idx_account_devices_push_token")
}

model account_settings {
  account_id          String    @id @db.Uuid
  notification_enable Boolean   @default(true)
  language            String    @default("vi") @db.VarChar(20)
  created_at          DateTime? @default(now()) @db.Timestamptz(6)
  updated_at          DateTime? @default(now()) @db.Timestamptz(6)
  accounts            accounts  @relation(fields: [account_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_account_settings_account_id")

  @@index([account_id], map: "idx_account_settings")
}

model notifications {
  id                      String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  account_id              String                    @db.Uuid
  title                   String
  body                    String?
  image_url               String?
  image_id                String?
  deep_link               String?
  data                    Json?
  is_read                 Boolean?                  @default(false)
  read_at                 DateTime?                 @db.Timestamptz(6)
  created_at              DateTime?                 @default(now()) @db.Timestamptz(6)
  updated_at              DateTime?                 @default(now()) @db.Timestamptz(6)
  notification_deliveries notification_deliveries[]
  accounts                accounts                  @relation(fields: [account_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_notifications_account_id")

  @@index([id], map: "idx_notifications")
  @@index([account_id], map: "idx_notifications_account_id")
}

model reminders {
  id           String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  account_id   String          @db.Uuid
  pet_id       String?         @db.Uuid
  title        String          @db.VarChar(200)
  description  String?         @db.VarChar(255)
  type         reminder_type
  status       reminder_status
  scheduled_at DateTime        @db.Timestamptz(6)
  created_at   DateTime?       @default(now()) @db.Timestamptz(6)
  updated_at   DateTime?       @default(now()) @db.Timestamptz(6)
  accounts     accounts        @relation(fields: [account_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_reminders_account_id")
  pets         pets?           @relation(fields: [pet_id], references: [id], onUpdate: NoAction, map: "fk_reminders_pet_id")

  @@index([id], map: "idx_reminders")
  @@index([account_id], map: "idx_reminders_account_id")
  @@index([pet_id], map: "idx_reminders_pet_id")
}

model notification_deliveries {
  id              String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  notification_id String               @db.Uuid
  device_id       String               @db.Uuid
  push_token      String?              @db.VarChar(512)
  status          notifications_status
  sent_at         DateTime?            @db.Timestamptz(6)
  error           String?
  created_at      DateTime?            @default(now()) @db.Timestamptz(6)
  updated_at      DateTime?            @default(now()) @db.Timestamptz(6)
  account_devices account_devices      @relation(fields: [device_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_notification_deliveries_device_id")
  notifications   notifications        @relation(fields: [notification_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_notification_deliveries_notification_id")

  @@index([id], map: "idx_notification_deliveries")
  @@index([device_id], map: "idx_notification_deliveries_device_id")
  @@index([error], map: "idx_notification_deliveries_error")
  @@index([notification_id], map: "idx_notification_deliveries_notification_id")
}

model budget_categories {
  id                  String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                String                @unique @db.VarChar(50)
  image_url           String?
  image_id            String?
  color               String?               @db.VarChar(50)
  created_at          DateTime?             @default(now()) @db.Timestamptz(6)
  updated_at          DateTime?             @default(now()) @db.Timestamptz(6)
  budget_transactions budget_transactions[]

  @@index([id], map: "idx_budget_categories")
  @@index([name], map: "idx_budget_categories_name")
}

model budget_transactions {
  id                String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  account_id        String            @db.Uuid
  category_id       String            @db.Uuid
  amount            Decimal           @db.Decimal(12, 2)
  description       String?           @db.VarChar(512)
  date              DateTime          @db.Timestamptz(6)
  created_at        DateTime?         @default(now()) @db.Timestamptz(6)
  updated_at        DateTime?         @default(now()) @db.Timestamptz(6)
  accounts          accounts          @relation(fields: [account_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_budget_transactions_account_id")
  budget_categories budget_categories @relation(fields: [category_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_budget_transactions_category_id")

  @@index([id], map: "idx_budget_transactions")
  @@index([account_id], map: "idx_budget_transactions_account_id")
  @@index([category_id], map: "idx_budget_transactions_category_id")
}

model budgets {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  account_id String    @db.Uuid
  amount     Decimal   @db.Decimal(12, 2)
  month      Int
  year       Int
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  updated_at DateTime? @default(now()) @db.Timestamptz(6)
  accounts   accounts  @relation(fields: [account_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_budget_transactions_account_id")

  @@unique([account_id, month, year], map: "budgets_user_month_year_unique")
  @@index([id], map: "idx_budgets")
  @@index([account_id], map: "idx_budgets_account_id")
}

model photo_comments {
  id                   String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  account_id           String           @db.Uuid
  photo_id             String           @db.Uuid
  parent_id            String?          @db.Uuid
  content              String
  deleted_at           DateTime?        @db.Timestamptz(6)
  reply_count          Int              @default(0)
  created_at           DateTime?        @default(now()) @db.Timestamptz(6)
  updated_at           DateTime?        @default(now()) @db.Timestamptz(6)
  accounts             accounts         @relation(fields: [account_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_photo_comments_account_id")
  photo_comments       photo_comments?  @relation("photo_commentsTophoto_comments", fields: [parent_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_photo_comments_parent_id")
  other_photo_comments photo_comments[] @relation("photo_commentsTophoto_comments")
  photos               photos           @relation(fields: [photo_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_photo_comments_photo_id")

  @@index([account_id], map: "idx_photo_comments_account_id")
  @@index([parent_id], map: "idx_photo_comments_parent_id")
  @@index([photo_id], map: "idx_photo_comments_photo_id")
}

model photo_likes {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  account_id String    @db.Uuid
  photo_id   String    @db.Uuid
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  updated_at DateTime? @default(now()) @db.Timestamptz(6)
  accounts   accounts  @relation(fields: [account_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_photo_likes_account_id")

  @@unique([photo_id, account_id])
  @@index([account_id], map: "idx_photo_likes_account_id")
  @@index([photo_id], map: "idx_photo_likes_photo_id")
}

model photo_views {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  account_id String    @db.Uuid
  photo_id   String    @db.Uuid
  view_at    DateTime? @default(now()) @db.Timestamptz(6)
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  updated_at DateTime? @default(now()) @db.Timestamptz(6)
  accounts   accounts  @relation(fields: [account_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_photo_views_account_id")

  @@unique([photo_id, account_id])
  @@index([account_id], map: "idx_photo_views_account_id")
  @@index([photo_id], map: "idx_photo_views_photo_id")
}

model photos {
  id             String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  account_id     String           @db.Uuid
  url            String?
  file_id        String?
  thumbnail_url  String?
  caption        String?          @db.VarChar(200)
  is_private     Boolean          @default(false)
  status         photos_status    @default(pending)
  view_count     Int              @default(0)
  like_count     Int              @default(0)
  comment_count  Int              @default(0)
  created_at     DateTime?        @default(now()) @db.Timestamptz(6)
  updated_at     DateTime?        @default(now()) @db.Timestamptz(6)
  photo_comments photo_comments[]
  accounts       accounts         @relation(fields: [account_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_photos_account_id")

  @@index([account_id], map: "idx_photos_account_id")
  @@index([created_at], map: "idx_photos_created_at")
  @@index([is_private], map: "idx_photos_is_private")
  @@index([status], map: "idx_photos_status")
}

enum subscription_tier {
  free
  premium
}

enum user_role {
  user
  admin
}

enum gender_enum {
  male
  female
  unknown
}

enum record_type {
  vaccination
  checkup
  surgery
  medication
}

enum species_enum {
  dog
  cat
  bird
  rabbit
  other
}

enum device_platform {
  android
  ios
  unknown
}

enum notifications_status {
  pending
  sent
  failed
}

enum reminder_status {
  pending
  sent
  cancelled
}

enum reminder_type {
  grooming
  feeding
  vaccination
  medication
}

enum photos_status {
  pending
  processing
  ready
  failed
}
