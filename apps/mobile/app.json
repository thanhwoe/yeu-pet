{
  "expo": {
    "name": "pet-care",
    "slug": "pet-care",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "notification": {
      "icon": "./assets/images/notification.png",
      "color": "#ffffff"
    },
    "scheme": "petcare",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.thanhwoe.petcare",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "Allow $(PRODUCT_NAME) to access your camera",
        "NSPhotoLibraryUsageDescription": "Allow $(PRODUCT_NAME) to access your photos",
        "NSLocationWhenInUseUsageDescription": "Allow $(PRODUCT_NAME) to access your location",
        "NSMicrophoneUsageDescription": "Allow $(PRODUCT_NAME) to access your microphone"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/splash-icon.png",
        "backgroundColor": "#F97E1F"
      },
      "edgeToEdgeEnabled": true,
      "softwareKeyboardLayoutMode": "resize",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "package": "com.thanhwoe.petcare"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#F97E1F"
        }
      ],
      [
        "expo-secure-store",
        {
          "configureAndroidBackup": false,
          "faceIDPermission": "Allow $(PRODUCT_NAME) to use Face ID."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow $(PRODUCT_NAME) to access your photos",
          "cameraPermission": "Allow $(PRODUCT_NAME) to access your camera"
        }
      ],
      [
        "expo-document-picker",
        {
          "iCloudContainerEnvironment": "Production"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow $(PRODUCT_NAME) to use your location."
        }
      ],
      "@react-native-firebase/app",
      "@react-native-firebase/messaging",
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static",
            "extraPods": [
              {
                "name": "GoogleUtilities",
                "modular_headers": true
              }
            ]
          }
        }
      ],
      [
        "./modules/firebase-messaging/withAndroidNotificationChannel.js",
        {
          "defaultChannelId": "general-notifications-v1",
          "sounds": [
            {
              "source": "./assets/sounds/notification.wav",
              "androidResourceName": "notification",
              "iosFileName": "notification.wav"
            },
            {
              "source": "./assets/sounds/fallback_notification.wav",
              "androidResourceName": "fallback_notification",
              "iosFileName": "fallback_notification.wav"
            }
          ],
          "channels": [
            {
              "id": "care-reminders-v1",
              "name": "Care reminders",
              "importance": "high",
              "sound": "notification",
              "vibration": true
            },
            {
              "id": "general-notifications-v1",
              "name": "General notifications",
              "importance": "high",
              "sound": "fallback_notification",
              "vibration": true
            }
          ]
        }
      ],
      [
        "expo-web-browser",
        {
          "experimentalLauncherActivity": true
        }
      ],
      [
        "expo-font",
        {
          "android": {
            "fonts": [
              {
                "fontFamily": "Nunito",
                "fontDefinitions": [
                  {
                    "path": "./assets/fonts/Nunito-Bold.ttf",
                    "weight": 700
                  },
                  {
                    "path": "./assets/fonts/Nunito-SemiBold.ttf",
                    "weight": 600
                  },
                  {
                    "path": "./assets/fonts/Nunito-Medium.ttf",
                    "weight": 500
                  },
                  {
                    "path": "./assets/fonts/Nunito-Regular.ttf",
                    "weight": 400
                  },
                  {
                    "path": "./assets/fonts/Nunito-Light.ttf",
                    "weight": 300
                  }
                ]
              }
            ]
          },
          "ios": {
            "fonts": [
              "./assets/fonts/Nunito-Bold.ttf",
              "./assets/fonts/Nunito-SemiBold.ttf",
              "./assets/fonts/Nunito-Medium.ttf",
              "./assets/fonts/Nunito-Regular.ttf",
              "./assets/fonts/Nunito-Light.ttf"
            ]
          }
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Allow $(PRODUCT_NAME) to access your photos.",
          "savePhotosPermission": "Allow $(PRODUCT_NAME) to save photos.",
          "isAccessMediaLocationEnabled": true,
          "granularPermissions": ["photo", "video"]
        }
      ],
      [
        "./modules/vnpay/withAndroidManifest.js",
        {
          "scheme": "petcare"
        }
      ],
      ["./modules/vnpay/withAndroidGradleProperties.js"]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ece16c3d-7c90-4b45-8744-cdcc47ef5d95"
      }
    },
    "runtimeVersion": "appVersion",
    "updates": {
      "url": "https://u.expo.dev/ece16c3d-7c90-4b45-8744-cdcc47ef5d95"
    },
    "owner": "thanhwoe"
  }
}
