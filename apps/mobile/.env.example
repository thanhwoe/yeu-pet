# API URL for YeuPet Backend (e.g. local or production endpoint)
EXPO_PUBLIC_API_URL=http://localhost:3000/api/v1

# Firebase native app configuration files. In EAS, configure these as secret
# file environment variables for each app variant.
FIREBASE_ANDROID_GOOGLE_SERVICES_FILE=/absolute/path/to/google-services.json
FIREBASE_IOS_GOOGLE_SERVICES_FILE=/absolute/path/to/GoogleService-Info.plist
