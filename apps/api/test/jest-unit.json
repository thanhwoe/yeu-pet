{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "../",
  "testEnvironment": "node",
  "testMatch": [
    "<rootDir>/src/app.controller.spec.ts",
    "<rootDir>/src/**/*.architecture.spec.ts",
    "<rootDir>/src/database/**/*.spec.ts",
    "<rootDir>/src/decorators/**/*.spec.ts",
    "<rootDir>/src/guards/**/*.spec.ts",
    "<rootDir>/src/interceptors/**/*.spec.ts",
    "<rootDir>/src/modules/shared/email/**/*.spec.ts",
    "<rootDir>/src/modules/shared/queue/**/*.spec.ts",
    "<rootDir>/src/modules/auth/**/*.spec.ts",
    "<rootDir>/src/modules/ai/**/*.spec.ts",
    "<rootDir>/src/modules/moderation/**/*.spec.ts",
    "<rootDir>/src/modules/subscription/**/*.spec.ts",
    "<rootDir>/src/modules/users/**/*.spec.ts",
    "<rootDir>/src/modules/pets/**/*.spec.ts",
    "<rootDir>/src/modules/photos/**/*.spec.ts",
    "<rootDir>/src/modules/reminders/**/*.spec.ts",
    "<rootDir>/src/modules/medical-records/**/*.spec.ts",
    "<rootDir>/src/modules/notifications/**/*.spec.ts",
    "<rootDir>/src/modules/user-devices/**/*.spec.ts",
    "<rootDir>/src/modules/budget/budgets/**/*.spec.ts",
    "<rootDir>/src/modules/budget/transactions/**/*.spec.ts",
    "<rootDir>/src/modules/sitter-booking/bookings/sitter-bookings.service.spec.ts",
    "<rootDir>/src/modules/sitter-booking/bookings/messages/**/*.spec.ts",
    "<rootDir>/src/modules/sitter-booking/sitters/**/*.spec.ts",
    "<rootDir>/src/modules/budget/categories/budget-categories.service.spec.ts"
  ],
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^\\./internal/(.*)\\.js$": "<rootDir>/src/generated/prisma/internal/$1.ts",
    "^\\./(enums|commonInputTypes|models)\\.js$": "<rootDir>/src/generated/prisma/$1.ts",
    "^(\\.{1,2}/.*)\\.js$": "$1",
    "^@app/(.*)$": "<rootDir>/src/$1"
  },
  "collectCoverageFrom": [
    "src/**/*.ts",
    "!src/**/*.spec.ts",
    "!src/generated/**"
  ],
  "coverageDirectory": "coverage"
}
