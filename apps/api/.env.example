# ─── Server ───────────────────────────────────────────
PORT=3000
NODE_ENV=development
API_PREFIX=api

# ─── Database (Supabase PostgreSQL) ──────────────────
# Connection pooling URL (for runtime)
DATABASE_URL=postgresql://postgres.xxxxx:YOUR_PASSWORD@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true
# Direct connection URL (for migrations)
DIRECT_URL=postgresql://postgres.xxxxx:YOUR_PASSWORD@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres

# ─── JWT ─────────────────────────────────────────────
JWT_SECRET=your-jwt-secret-here
JWT_ACCESS_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-jwt-refresh-secret-here
# 30 days in milliseconds
JWT_REFRESH_EXPIRES_IN=2592000000

# ─── Infobip (SMS OTP) ───────────────────────────────
INFOBIP_BASE_URL=https://your-subdomain.api.infobip.com
INFOBIP_API_KEY=your-infobip-api-key
INFOBIP_SMS_FROM=YeuPet
OTP_EXPIRATION_MINUTES=10

# ─── Cloudinary (File Upload) ────────────────────────
CLOUDINARY_NAME=your-cloudinary-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret
CLOUDINARY_UPLOAD_FOLDER=uploads
CLOUDINARY_USER_FOLDER=users
MAX_FILE_SIZE=5242880

# ─── Redis ───────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ─── Resend (Transactional Email) ───────────────────
RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL=noreply@yeupet.com
RESEND_FROM_NAME=YeuPet
RESEND_WEBHOOK_SECRET=your-resend-webhook-secret
EMAIL_OTP_EXPIRES_MINUTES=10
EMAIL_OTP_MAX_ATTEMPTS=5
EMAIL_OTP_RESEND_COOLDOWN_SECONDS=60
EMAIL_OTP_MAX_RESENDS=5

# ─── Firebase ───────────────────────────────────────
GOOGLE_APPLICATION_CREDENTIALS=./yeu-pet-firebase-adminsdk.json

# ─── Pet Care AI ────────────────────────────────────
# Supported values: fallback, openai, gemini
AI_PROVIDER=fallback
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=your-google-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# ─── Sentry ───────────────────────────────────────────
SENTRY_DSN=your-sentry-dsn-here

# ─── PostHog (Analytics) ──────────────────────────────
POSTHOG_API_KEY=your-posthog-api-key-here
POSTHOG_HOST=https://us.i.posthog.com

# ─── RevenueCat Subscriptions ────────────────────────
REVENUECAT_WEBHOOK_SECRET=your-revenuecat-webhook-authorization-value
REVENUECAT_SECRET_KEY=your-revenuecat-secret-api-key
REVENUECAT_PREMIUM_ENTITLEMENT_ID=your-premium-entitlement-id
