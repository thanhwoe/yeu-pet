{
  "name": "yeu-pet",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev": "turbo run dev",
    "dev:api": "turbo run dev --filter=@yeu-pet/api",
    "dev:mobile": "turbo run dev --filter=@yeu-pet/mobile",
    "build": "turbo run build",
    "build:api": "turbo run build --filter=@yeu-pet/api",
    "build:mobile": "turbo run build --filter=@yeu-pet/mobile",
    "build:tsconfig": "cd packages/tsconfig && pnpm build",
    "build:eslint-config": "cd packages/eslint-config && pnpm build",
    "lint": "turbo run lint --filter=@yeu-pet/api --filter=@yeu-pet/mobile",
    "lint:tsconfig": "cd packages/tsconfig && pnpm lint",
    "lint:eslint-config": "cd packages/eslint-config && pnpm lint",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules",
    "docker:up": "docker compose up",
    "docker:up:d": "docker compose up -d",
    "docker:down": "docker compose down -v",
    "docker:build": "docker compose build",
    "docker:build:no-cache": "docker compose build --no-cache",
    "docker:dev": "docker compose up --build",
    "docker:logs": "docker compose logs -f api"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "eslint": "^9.18.0",
    "prettier": "^3.4.2",
    "turbo": "^2.0.0",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  }
}
